/*
 * Dropout Regularization in PLingua
 * P-Systems membrane computing implementation of Dropout.
 *
 * Reference: Srivastava et al. (2014) "Dropout: A Simple Way to Prevent
 *            Neural Networks from Overfitting"
 *
 * During training each unit is independently zeroed with probability p.
 * The surviving units are scaled by 1/(1-p) (inverted dropout).
 * During evaluation, dropout is disabled (identity pass-through).
 *
 * Extensions implemented:
 *   - Standard Dropout           (unit-level)
 *   - Spatial Dropout 2D         (channel-level, for conv layers)
 *   - Alpha Dropout              (preserves self-normalising property)
 *   - DropConnect                (drop weights instead of activations)
 */

@model<membrane_computing>

@import "nn.pli"

/* ============================================================================
 * STANDARD DROPOUT
 * p       : probability of zeroing a unit
 * Objects in membrane:
 *   input{i, v}     -- activation i with value v
 *   mask{i, keep}   -- binary mask for unit i (1=keep, 0=drop)
 *   mode{train|eval}
 * ============================================================================ */

@module dropout(p)
{
    /* p is stored as integer 0-100 (percentage) */

    @initial
    {
        [dropout_layer
            drop_prob{p}
            mode{train}
        ]'main
    }

    /* TRAINING: generate binary mask and apply inverted scaling */

    /* Generate random mask for each input unit */
    @rules generate_mask
    {
        [input{i, v}, drop_prob{dp}, mode{train}]'dropout_layer ->
            [input{i, v}, mask{i, (random(0, 100) >= dp ? 1 : 0)}]'dropout_layer
    }

    /* Apply mask and scale: output = (mask / (1 - p)) * input */
    @rules apply_mask_train
    {
        [input{i, v}, mask{i, 1}, drop_prob{dp}]'dropout_layer ->
            [output{i, v * 100 / (100 - dp)}]'dropout_layer

        [input{i, v}, mask{i, 0}]'dropout_layer ->
            [output{i, 0}]'dropout_layer
    }

    /* EVALUATION: identity pass-through */
    @rules eval_passthrough
    {
        [input{i, v}, mode{eval}]'dropout_layer ->
            [output{i, v}]'dropout_layer
    }

    /* BACKWARD: propagate gradient through mask */
    @rules backward_train
    {
        [grad_out{i, g}, mask{i, 1}, drop_prob{dp}]'dropout_layer ->
            [grad_in{i, g * 100 / (100 - dp)}]'dropout_layer

        [grad_out{i, g}, mask{i, 0}]'dropout_layer ->
            [grad_in{i, 0}]'dropout_layer
    }

    @rules backward_eval
    {
        [grad_out{i, g}, mode{eval}]'dropout_layer ->
            [grad_in{i, g}]'dropout_layer
    }

    /* Send input gradients upstream */
    @rules send_grad
    {
        [grad_in{i, g}]'dropout_layer ->
            []'dropout_layer (grad{i, g}, out)
    }

    /* Mode switching */
    @rules set_train
    {
        [set_mode{train}]'dropout_layer -> [mode{train}]'dropout_layer
    }

    @rules set_eval
    {
        [set_mode{eval}]'dropout_layer -> [mode{eval}]'dropout_layer
    }

    /* Cleanup masks after each forward pass */
    @rules cleanup_masks
    {
        [mask{i, m}]'dropout_layer -> []'dropout_layer
    }
}

/* ============================================================================
 * SPATIAL DROPOUT 2D
 * Drops entire feature map channels (used with Conv2D layers).
 * A single mask value per channel is broadcast to all spatial positions.
 * channel_index: c  position: (r, col)  input{c, r, col, v}
 * ============================================================================ */

@module spatial_dropout2d(p)
{
    @initial
    {
        [spatial_dropout
            drop_prob{p}
            mode{train}
        ]'main
    }

    /* One mask per channel */
    @rules generate_channel_mask
    {
        [channel{c}, drop_prob{dp}, mode{train}]'spatial_dropout ->
            [channel_mask{c, (random(0, 100) >= dp ? 1 : 0)}]'spatial_dropout
    }

    /* Apply channel mask to all spatial positions */
    @rules apply_spatial_mask_train
    {
        [input{c, r, col, v}, channel_mask{c, 1}, drop_prob{dp}]'spatial_dropout ->
            [output{c, r, col, v * 100 / (100 - dp)}]'spatial_dropout

        [input{c, r, col, v}, channel_mask{c, 0}]'spatial_dropout ->
            [output{c, r, col, 0}]'spatial_dropout
    }

    @rules eval_passthrough
    {
        [input{c, r, col, v}, mode{eval}]'spatial_dropout ->
            [output{c, r, col, v}]'spatial_dropout
    }

    /* Backward */
    @rules backward_train
    {
        [grad_out{c, r, col, g}, channel_mask{c, 1}, drop_prob{dp}]'spatial_dropout ->
            [grad_in{c, r, col, g * 100 / (100 - dp)}]'spatial_dropout

        [grad_out{c, r, col, g}, channel_mask{c, 0}]'spatial_dropout ->
            [grad_in{c, r, col, 0}]'spatial_dropout
    }

    @rules cleanup_masks
    {
        [channel_mask{c, m}]'spatial_dropout -> []'spatial_dropout
    }

    @rules mode_switch
    {
        [set_mode{train}]'spatial_dropout -> [mode{train}]'spatial_dropout
        [set_mode{eval}]'spatial_dropout  -> [mode{eval}]'spatial_dropout
    }
}

/* ============================================================================
 * ALPHA DROPOUT
 * Preserves self-normalising properties (mean and variance of the input).
 * Applied after SELU activations.
 *
 * Constants: alpha' = -lambda*alpha ≈ -1.7581, lambda ≈ 1.0507
 * For unit with value x:
 *   if keep: x
 *   if drop: alpha_prime
 * Then affine transform to restore moments:
 *   a = 1/sqrt((1-p)*(1+p*alpha'^2))
 *   b = -a*(p*alpha')
 *   output = a*x + b
 * ============================================================================ */

@module alpha_dropout(p)
{
    /* Fixed-point constants (×1000) */
    /* alpha_prime ≈ -1758  (×1000) */
    /* a_scale computed from p       */

    @initial
    {
        [alpha_drop
            drop_prob{p}
            alpha_prime{-1758}      /* ×1000 */
            mode{train}
        ]'main
    }

    @rules generate_mask
    {
        [input{i, v}, drop_prob{dp}, mode{train}]'alpha_drop ->
            [input{i, v}, mask{i, (random(0, 100) >= dp ? 1 : 0)}]'alpha_drop
    }

    @rules apply_alpha_dropout
    {
        /* Keep: replace with alpha_prime (scaled) */
        [input{i, v}, mask{i, 0}, alpha_prime{ap}]'alpha_drop ->
            [pre_affine{i, ap}]'alpha_drop

        /* Drop: keep value */
        [input{i, v}, mask{i, 1}]'alpha_drop ->
            [pre_affine{i, v}]'alpha_drop
    }

    /* Affine restoration of moments
     * Simplified: a ≈ 1, b ≈ 0 for small p (full computation omitted)
     */
    @rules affine_restore
    {
        [pre_affine{i, x}, drop_prob{dp}]'alpha_drop ->
            [output{i, x}]'alpha_drop
    }

    @rules eval_passthrough
    {
        [input{i, v}, mode{eval}]'alpha_drop ->
            [output{i, v}]'alpha_drop
    }

    @rules cleanup
    {
        [mask{i, m}]'alpha_drop        -> []'alpha_drop
        [pre_affine{i, x}]'alpha_drop  -> []'alpha_drop
    }

    @rules mode_switch
    {
        [set_mode{train}]'alpha_drop -> [mode{train}]'alpha_drop
        [set_mode{eval}]'alpha_drop  -> [mode{eval}]'alpha_drop
    }
}

/* ============================================================================
 * DROPCONNECT
 * Instead of zeroing activations, zeroes individual weights during training.
 * At inference time uses the full weight matrix.
 * ============================================================================ */

@module dropconnect(p)
{
    @initial
    {
        [dropconnect_layer
            drop_prob{p}
            mode{train}
        ]'main
    }

    /* During forward pass in training, mask each weight */
    @rules mask_weights_train
    {
        [weight{i, j, w}, drop_prob{dp}, mode{train}]'dropconnect_layer ->
            [weight_masked{i, j, w * (random(0, 100) >= dp ? 1 : 0)}]'dropconnect_layer
    }

    /* Use masked weights for forward computation */
    @rules forward_train
    {
        [input{j, v}, weight_masked{i, j, wm}]'dropconnect_layer ->
            [partial_sum{i, v * wm}]'dropconnect_layer
        [partial_sum{i, s1}, partial_sum{i, s2}]'dropconnect_layer ->
            [partial_sum{i, s1 + s2}]'dropconnect_layer
        [partial_sum{i, s}, bias{i, b}]'dropconnect_layer ->
            [output{i, s + b}]'dropconnect_layer
    }

    /* Eval uses full weights */
    @rules forward_eval
    {
        [input{j, v}, weight{i, j, w}, mode{eval}]'dropconnect_layer ->
            [partial_sum_eval{i, v * w}]'dropconnect_layer
        [partial_sum_eval{i, s1}, partial_sum_eval{i, s2}]'dropconnect_layer ->
            [partial_sum_eval{i, s1 + s2}]'dropconnect_layer
        [partial_sum_eval{i, s}, bias{i, b}]'dropconnect_layer ->
            [output{i, s + b}]'dropconnect_layer
    }

    /* Backward: gradient only flows through kept connections */
    @rules backward
    {
        [grad_out{i, g}, weight_masked{i, j, wm}]'dropconnect_layer ->
            [grad_in{j, g * wm}]'dropconnect_layer
        [grad_in{j, g1}, grad_in{j, g2}]'dropconnect_layer ->
            [grad_in{j, g1 + g2}]'dropconnect_layer
    }

    @rules cleanup
    {
        [weight_masked{i, j, wm}]'dropconnect_layer -> []'dropconnect_layer
    }

    @rules mode_switch
    {
        [set_mode{train}]'dropconnect_layer -> [mode{train}]'dropconnect_layer
        [set_mode{eval}]'dropconnect_layer  -> [mode{eval}]'dropconnect_layer
    }
}

/* ============================================================================
 * EXAMPLE: Regularised MLP with Dropout
 * ============================================================================ */

@model dropout_mlp(input_size, hidden_size, output_size, drop_p)
{
    @membrane_structure
    {
        [main
            [layer1   linear_layer(input_size, hidden_size)]'main
            [act1     relu_activation]'main
            [drop1    dropout(drop_p)]'main
            [layer2   linear_layer(hidden_size, hidden_size)]'main
            [act2     relu_activation]'main
            [drop2    dropout(drop_p)]'main
            [layer3   linear_layer(hidden_size, output_size)]'main
        ]
    }

    @hyperparams
    {
        dropout_rate: drop_p
        description: "Two hidden layers with ReLU activation and Dropout"
    }
}

/* ============================================================================
 * DOCUMENTATION
 * ============================================================================ */

@info
{
    name: "Dropout in PLingua"
    version: "1.0.0"
    description: "Dropout regularisation variants as P-Systems membranes"
    features: [
        "Standard Dropout (inverted scaling)",
        "Spatial Dropout 2D (channel-level)",
        "Alpha Dropout (self-normalising)",
        "DropConnect (weight masking)",
        "Train/eval mode switching",
        "Full backward pass support"
    ]
}
